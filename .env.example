# ─────────────────────────────────────────────────────────────
# Scout — environment
# Copy this file to `.env` and fill in ONE model key. That's the
# only required setting. .env is gitignored — your keys stay local.
# ─────────────────────────────────────────────────────────────

# REQUIRED: one model API key.
# Anthropic is the preferred model (see agent.yaml); OpenAI is the fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── optional ──────────────────────────────────────────────────

# Structured Twitter/X reads through Xquik. Leave empty to use local backends.
XQUIK_API_KEY=

# Web UI port (default 4545)
# SCOUT_UI_PORT=4545

# Twitter/X reads whatever account is logged into your browser (cookie-replay).
# Leave unset to use your default profile, or pin a specific browser/profile:
# TWITTER_BROWSER=chrome
# TWITTER_CHROME_PROFILE=Default

# Allow WRITE actions (post/like/follow). OFF by default — Scout is read-only.
# Only set this to 1 if you explicitly want the agent to act on your accounts.
# SCOUT_ALLOW_WRITES=0
